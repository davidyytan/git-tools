# Git Tools Configuration

# ====== LLM PROVIDER ======
# Provider: "openrouter", "kimicli"
# Uncomment ONE provider section below and keep only the matching
# GIT_TOOLS_DEFAULT_MODEL override enabled if you set one.
# Default provider:
# GIT_TOOLS_PROVIDER=openrouter

# --- OpenRouter provider ---
# 1. Get API key from https://openrouter.ai/keys
# 2. Uncomment OPENROUTER_API_KEY and optionally leave provider as openrouter
# OPENROUTER_API_KEY=sk-or-...
# GIT_TOOLS_API_BASE=https://openrouter.ai/api/v1
# GIT_TOOLS_DEFAULT_MODEL=qwen/qwen3.5-397b-a17b

# --- Kimi Code provider (via Kimi CLI endpoint) ---
# 1. Get API key from Kimi Code membership page (sk-kimi-... format)
# 2. Uncomment MOONSHOT_API_KEY and set GIT_TOOLS_PROVIDER=kimicli
# MOONSHOT_API_KEY=sk-kimi-...
# GIT_TOOLS_API_BASE=https://api.kimi.com/coding/v1
# GIT_TOOLS_DEFAULT_MODEL=kimi-k2.5

# ====== GIT TOOLS SETTINGS ======
# Uncomment only when overriding the default value.

# LLM defaults
# The default model comes from mappings.json, or mappings.json.example if mappings.json is absent.
# Provider-specific model examples are shown in the provider sections above.
# GIT_TOOLS_DEFAULT_TEMPERATURE=0.2
# GIT_TOOLS_DEFAULT_MAX_TOKENS=8000
# GIT_TOOLS_DEFAULT_MAX_RETRIES=1
# GIT_TOOLS_DEFAULT_RETRY_DELAY=1.0

# Token limits for diff processing
# GIT_TOOLS_DEFAULT_TOKEN_LIMIT=200000
# GIT_TOOLS_DEFAULT_ISSUE_PR_TOKEN_LIMIT=200000
# GIT_TOOLS_LARGE_DIFF_THRESHOLD=5000

# Files below this token count are never dropped during context limiting
# GIT_TOOLS_MIN_FILE_TOKEN_THRESHOLD=1000

# Console width offset to prevent border wrapping (Rich issue #7)
# GIT_TOOLS_CONSOLE_WIDTH_OFFSET=-2
